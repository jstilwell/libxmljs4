{
  "name": "libxmljs4",
  "author": "Jesse Stilwell <jesse.stilwell@gmail.com>",
  "contributors": [
    "marudor",
    "Jeff Smick",
    "Marco Rogers"
  ],
  "packageManager": "pnpm@9.15.9",
  "description": "libxml bindings for v8 javascript engine",
  "version": "1.1.0",
  "scripts": {
    "build": "node-gyp rebuild",
    "build:ts": "tsc && tsc -p tsconfig.esm.json",
    "prebuild": "prebuildify --napi",
    "install": "node-gyp-build",
    "test": "vitest run",
    "tsd": "tsd",
    "lint": "eslint ."
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jstilwell/libxmljs4.git"
  },
  "bugs": {
    "url": "https://github.com/jstilwell/libxmljs4/issues"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.mts",
        "default": "./dist/index.mjs"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      }
    }
  },
  "license": "MIT",
  "tsd": {
    "directory": "."
  },
  "engines": {
    "node": ">=22"
  },
  "files": [
    "dist",
    "prebuilds",
    "src",
    "vendor",
    "binding.gyp",
    "Makefile"
  ],
  "dependencies": {
    "node-addon-api": "^8.0.0",
    "node-gyp": "^11.2.0",
    "node-gyp-build": "^4.8.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "vitest": "^3.0.0",
    "prebuildify": "^6.0.0",
    "eslint": "^9.0.0",
    "@eslint/js": "^9.0.0",
    "eslint-config-prettier": "^10.0.0",
    "globals": "^16.0.0",
    "prettier": "^3.5.3",
    "tsd": "^0.32.0",
    "typescript": "^5.8.3"
  }
}
